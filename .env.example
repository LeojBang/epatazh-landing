# Скопируй этот файл в .env и впиши реальные значения.
# .env НЕ коммить в git — он в .gitignore.

# --- SMTP (Яндекс) ---
# Хост и порт почтового сервера. Для Яндекса — как ниже.
SMTP_HOST=mail.hosting.reg.ru
SMTP_PORT=465

# Ящик-отправитель и пароль ПРИЛОЖЕНИЯ (не основной пароль от почты!).
# Пароль приложения создаётся в настройках Яндекс ID → Безопасность → Пароли приложений.
SMTP_USER=info@epatajextra.ru
SMTP_PASSWORD=your_app_password

# От кого уходит письмо (обычно тот же ящик).
MAIL_FROM=info@epatajextra.ru

# Кому приходят заявки. Можно несколько через запятую:
# MAIL_TO=zakaz@epatazh.ru, info@epatazh.ru
MAIL_TO=info@epatajextra.ru, m.merkulovdodo@gmail.com
SMTP_FROM_NAME=Магазин Эпатаж

# --- защита от спама (необязательно менять) ---
# Не больше RATE_LIMIT заявок с одного IP за RATE_WINDOW_MIN минут.
RATE_LIMIT=5
RATE_WINDOW_MIN=10


